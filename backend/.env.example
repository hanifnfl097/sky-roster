# ===========================================
# SkyRoster Backend — Environment Variables
# ===========================================
# Copy this file to `.env` and fill in the values.
# See docs/tech/env-config.md for full documentation.

# Application
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
LOG_LEVEL=INFO

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=skyroster_dev
DB_USERNAME=
DB_PASSWORD=

# Authentication (JWT)
# IMPORTANT: Use a strong secret, minimum 64 characters (HS512)
JWT_SECRET=
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# Geofencing
GEOFENCE_RADIUS_METERS=500
SIGN_ON_WINDOW_MINUTES=120

# FTL Configuration (CASR 121 / ICAO Defaults)
FTL_MAX_7_DAY_HOURS=30
FTL_MAX_MONTHLY_HOURS=100
FTL_MAX_YEARLY_HOURS=1050
FTL_MIN_REST_HOURS=12

# Cron Jobs
CRON_DOC_EXPIRY_SCHEDULE=0 0 6 * * *
DOC_EXPIRY_WARNING_DAYS=30,14,7

# External Services (optional)
REDIS_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FCM_SERVER_KEY=
SENTRY_DSN=
